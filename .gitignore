# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/.playwright-mcp/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# cron wrapper log (VM-local)
/scripts/refresh.log

# env files
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database
/data/*.db
/data/*.db-journal

# Companies dataset — the source of truth is the Vercel Blob, written weekly by
# the VM scraper. The committed file drifts the moment the next scrape runs, so
# we don't track it. Local dev reads the Blob via BLOB_URL (.env.local); the
# untracked file remains only as an offline fallback.
/data/companies.json

# company logos (downloaded via npm run download-icons)
/public/logos/

# Local-dev feedback submissions (production uses Vercel Blob)
data/feedback/
